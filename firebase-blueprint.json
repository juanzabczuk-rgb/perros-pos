{
  "entities": {
    "User": {
      "title": "User",
      "description": "Application user profile",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["owner", "admin", "seller"] },
        "branch_id": { "type": "string" },
        "branch_name": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "role", "branch_id"]
    },
    "Branch": {
      "title": "Branch",
      "description": "Store branch",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "location": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["name"]
    },
    "Category": {
      "title": "Category",
      "description": "Product category",
      "type": "object",
      "properties": {
        "name": { "type": "string" }
      },
      "required": ["name"]
    },
    "Product": {
      "title": "Product",
      "description": "Inventory item",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "sku": { "type": "string" },
        "category": { "type": "string" },
        "cost": { "type": "number" },
        "margin": { "type": "number" },
        "price": { "type": "number" },
        "is_composite": { "type": "boolean" },
        "image_url": { "type": "string" },
        "components": { "type": "array" }
      },
      "required": ["name", "sku", "category", "cost", "price"]
    },
    "Customer": {
      "title": "Customer",
      "description": "Customer profile",
      "type": "object",
      "properties": {
        "first_name": { "type": "string" },
        "last_name": { "type": "string" },
        "dni": { "type": "string" },
        "phone": { "type": "string" },
        "points": { "type": "number" }
      },
      "required": ["first_name", "last_name", "dni"]
    },
    "Sale": {
      "title": "Sale",
      "description": "Sales transaction",
      "type": "object",
      "properties": {
        "branch_id": { "type": "string" },
        "user_id": { "type": "string" },
        "user_name": { "type": "string" },
        "customer_id": { "type": "string" },
        "shift_id": { "type": "string" },
        "total": { "type": "number" },
        "discount": { "type": "number" },
        "payment_type": { "type": "string" },
        "status": { "type": "string", "enum": ["completed", "refunded"] },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["branch_id", "user_id", "total", "payment_type", "status"]
    },
    "Shift": {
      "title": "Shift",
      "description": "Work shift",
      "type": "object",
      "properties": {
        "user_id": { "type": "string" },
        "branch_id": { "type": "string" },
        "start_time": { "type": "string", "format": "date-time" },
        "end_time": { "type": "string", "format": "date-time" },
        "initial_cash": { "type": "number" },
        "expected_cash": { "type": "number" },
        "real_cash": { "type": "number" },
        "notes": { "type": "string" },
        "status": { "type": "string", "enum": ["open", "closed"] }
      },
      "required": ["user_id", "branch_id", "start_time", "initial_cash", "status"]
    },
    "CashMovement": {
      "title": "CashMovement",
      "description": "Cash in/out during shift",
      "type": "object",
      "properties": {
        "shift_id": { "type": "string" },
        "type": { "type": "string", "enum": ["income", "expense"] },
        "amount": { "type": "number" },
        "description": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["shift_id", "type", "amount", "description"]
    },
    "RolePermission": {
      "title": "RolePermission",
      "description": "Module access per role",
      "type": "object",
      "properties": {
        "modules": { "type": "array" }
      },
      "required": ["modules"]
    },
    "Stock": {
      "title": "Stock",
      "description": "Product stock in branch",
      "type": "object",
      "properties": {
        "quantity": { "type": "number" },
        "lastUpdated": { "type": "string", "format": "date-time" }
      },
      "required": ["quantity"]
    }
  },
  "firestore": {
    "/users": { "schema": "User", "description": "Users collection" },
    "/branches": { "schema": "Branch", "description": "Branches collection" },
    "/categories": { "schema": "Category", "description": "Product categories" },
    "/products": { "schema": "Product", "description": "Products catalog" },
    "/customers": { "schema": "Customer", "description": "Customers database" },
    "/sales": { "schema": "Sale", "description": "Sales records" },
    "/sales/{saleId}/items": { "schema": "object", "description": "Items in a sale" },
    "/shifts": { "schema": "Shift", "description": "Work shifts" },
    "/cash_movements": { "schema": "CashMovement", "description": "Cash movements" },
    "/role_permissions": { "schema": "RolePermission", "description": "Role permissions" },
    "/branches/{branchId}/stock": { "schema": "Stock", "description": "Branch inventory" }
  }
}
