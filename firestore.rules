rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/empleados/$(request.auth.uid)).data;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (((request.auth.token.email == "juanzabczuk@gmail.com" || request.auth.token.email == "perrosrosarinos@gmail.com") && request.auth.token.email_verified == true) ||
         getUserData().role == 'admin' || getUserData().role == 'owner');
    }

    function isOwner() {
      return isAuthenticated() && getUserData().role == 'owner';
    }

    function isOwnerOrAdmin() {
      return isAdmin() || isOwner();
    }

    function isDocOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    // Domain Validators
    function isValidUser(data) {
      return data.keys().hasAll(['name', 'email', 'role', 'branch_id']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.email is string && data.role in ['owner', 'admin', 'seller'];
    }

    // Empleados collection
    match /empleados/{userId} {
      allow read: if isAuthenticated(); // Allow listing operators for selection
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && 
                    (request.auth.uid == userId || isOwnerOrAdmin());
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && 
                    (isOwnerOrAdmin() || (request.auth.uid == userId && request.resource.data.role == resource.data.role));
      allow delete: if isOwnerOrAdmin();
    }

    // Branches, Categories, Products, RolePermissions
    match /branches/{branchId} {
      allow read: if isAuthenticated();
      allow write: if isOwnerOrAdmin();
    }
    match /categories/{categoryId} {
      allow read: if isAuthenticated();
      allow write: if isOwnerOrAdmin();
    }
    match /products/{productId} {
      allow read: if isAuthenticated();
      allow write: if isOwnerOrAdmin();
    }
    match /role_permissions/{roleId} {
      allow read: if isAuthenticated();
      allow write: if isOwnerOrAdmin();
    }

    // Customers
    match /customers/{customerId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if isOwnerOrAdmin();
    }

    // Sales
    match /sales/{saleId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isOwnerOrAdmin(); // For refunds
      allow delete: if isOwnerOrAdmin();
    }

    // Shifts and Cash Movements
    match /shifts/{shiftId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if isOwnerOrAdmin();
    }
    match /cash_movements/{movementId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if isOwnerOrAdmin();
    }

    // Stock
    match /branches/{branchId}/stock/{productId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }
  }
}
